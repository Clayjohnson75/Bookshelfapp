{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "@vercel/node"]
  },
  "include": [
    "api/**/*"
  ],
  "exclude": [
    "node_modules",
    "tabs/**/*",
    "services/**/*",
    "app/**/*",
    "screens/**/*",
    "auth/**/*",
    "lib/**/*"
  ]
}

